# GrantPilot Backend — environment variable template
# Copy to .env and fill in values for local development.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Required for production — set a strong random string (e.g. openssl rand -hex 32)
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-strong-random-secret

# ---------------------------------------------------------------------------
# Database — defaults to SQLite for local dev; set to Postgres URL for production
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///./grantpilot.db
# DATABASE_URL=postgresql://user:password@localhost:5432/grantpilot

# ---------------------------------------------------------------------------
# AI APIs — optional; real analysis requires ANTHROPIC_API_KEY
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Storage — defaults to local uploads/ directory
# ---------------------------------------------------------------------------
UPLOAD_DIR=uploads

# ---------------------------------------------------------------------------
# Optional settings
# ---------------------------------------------------------------------------
JWT_EXPIRE_DAYS=7
DEBUG=false
