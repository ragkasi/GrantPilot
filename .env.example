# GrantPilot root docker-compose variables
# Copy to .env in the project root, then run docker-compose up.
# NEVER commit .env to version control.

# ---------------------------------------------------------------------------
# Required for production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-strong-random-secret

# ---------------------------------------------------------------------------
# Postgres password for the docker-compose stack
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=devpassword

# ---------------------------------------------------------------------------
# AI APIs
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# In production replace with your actual domain
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Frontend API URL (used at Next.js build time — must be the public backend URL)
# For local docker-compose: http://localhost:8000
# For production: https://api.yourdomain.com
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
DEBUG=false
