# grant-context-mcp — environment variable template
# Set these before running the MCP server.
# Never commit .env to version control.

# Required for live AI analysis (grant extraction, evidence matching)
ANTHROPIC_API_KEY=

# Database URL — must point to the same DB as the backend
DATABASE_URL=sqlite:///../../backend/grantpilot.db

# Upload directory — must match the backend's UPLOAD_DIR
UPLOAD_DIR=../../backend/uploads
